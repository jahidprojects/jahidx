rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: users
    // Document ID: {userId} (Firebase Auth UID)
    // Fields:
    //   - uid: string (required) - Firebase Auth UID
    //   - username: string (required, < 50 chars) - User's display name
    //   - avatar: string (required, < 500 chars) - URL to profile image
    //   - balance: number (required, >= 0) - DUCK balance
    //   - tonBalance: number (required, >= 0) - TON balance
    //   - wins: number (required, >= 0) - Total wins
    //   - volume: number (required, >= 0) - Total volume
    //   - spinsCount: number (required, >= 0) - Total games played
    //   - completedTasks: list of strings (required, < 1000 items) - Task IDs
    //   - role: string (required, ['user', 'admin'])
    //   - tgId: number (optional) - Telegram User ID
    //   - welcomeBonusClaimed: boolean (optional)
    //   - referralCode: string (optional, < 20 chars) - Referral code
    //   - referredBy: string (optional, < 50 chars) - UID of referrer
    //
    // Collection: games
    // Document ID: {gameId}
    // Fields:
    //   - id: string (optional)
    //   - players: list of objects (required, < 50 items) - Player data
    //   - totalPot: number (required, >= 0) - Total pot
    //   - winner: map (optional) - Winner data
    //   - status: string (required, ['waiting', 'drawing', 'winner'])
    //   - createdAt: timestamp (optional)
    //   - updatedAt: timestamp (optional)
    // ===============================================================

    // Collection: transactions
    // Document ID: {transactionId}
    // Fields:
    //   - id: string (required)
    //   - uid: string (required)
    //   - amount: number (required, > 0)
    //   - type: string (required, ['deposit', 'withdrawal'])
    //   - status: string (required, ['pending', 'completed', 'failed'])
    //   - createdAt: timestamp (required)
    //
    // Collection: winners
    // Document ID: {winnerId}
    // Fields:
    //   - id: string (required)
    //   - gameId: string (required)
    //   - uid: string (required)
    //   - username: string (required)
    //   - avatar: string (required)
    //   - amount: number (required, >= 0)
    //   - winChance: number (required, >= 0)
    //   - createdAt: timestamp (required)
    //
    // Collection: stats
    // Document ID: winners
    // Fields:
    //   - lastWinner: map (required)
    //   - topWinner: map (required)
    //
    // Collection: tasks
    // Document ID: {taskId}
    // Fields:
    //   - id: string (required)
    //   - title: string (required)
    //   - reward: number (required)
    //   - type: string (required, ['daily', 'partner', 'achievement', 'social'])
    //   - btn: string (optional)
    //   - link: string (optional)
    //   - completedCount: number (optional)
    //
    // Collection: promoCodes
    // Document ID: {codeId}
    // Fields:
    //   - code: string (required)
    //   - reward: number (required)
    //   - supply: number (required)
    //   - claimedBy: list (optional)
    //
    // Collection: referralLinks
    // Document ID: {linkId}
    // Fields:
    //   - id: string (required)
    //   - name: string (required)
    //   - joins: number (optional)
    //   - ads: number (optional)
    //   - revenue: number (optional)
    //
    // Collection: withdrawalOffers
    // Document ID: {offerId}
    // Fields:
    //   - id: string (required)
    //   - title: string (required)
    //   - minAmount: number (required)
    //   - maxAmount: number (required)
    //
    // Collection: analytics
    // Document ID: global
    // Fields:
    //   - totalUsers: number
    //   - joinedToday: number
    //   - activeToday: number
    //   - rewardAds: number
    //   - interstitials: number
    //   - totalSpins: number
    //   - pendingWithdrawals: number
    //   - totalRevenue: number
    //   - promosClaimed: number
    //   - tasksDone: number
    //   - totalBalance: number
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        ((exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
          (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('tgId', 0) in [6686954447, 1678112785, 5968063026])) ||
         (request.auth.token.email == "jahidproject8@gmail.com"));
    }

    function isAllowedAdmin(data) {
      return data.role == 'admin' && 
             (data.get('tgId', 0) in [6686954447, 1678112785, 5968063026] || 
              (request.auth.token.email == "jahidproject8@gmail.com"));
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'username', 'avatar', 'balance', 'tonBalance', 'wins', 'volume', 'completedTasks', 'role']) &&
             data.uid == request.auth.uid &&
             data.username is string && data.username.size() > 0 && data.username.size() < 50 &&
             data.avatar is string && data.avatar.size() < 500 &&
             data.balance is number && data.balance >= 0 &&
             data.tonBalance is number && data.tonBalance >= 0 &&
             data.wins is number && data.wins >= 0 &&
             data.volume is number && data.volume >= 0 &&
             data.completedTasks is list && data.completedTasks.size() < 1000 &&
             data.role in ['user', 'admin'] &&
             (!('tgId' in data) || data.tgId == null || data.tgId is int) &&
             (!('spinsCount' in data) || data.spinsCount is number) &&
             (!('welcomeBonusClaimed' in data) || data.welcomeBonusClaimed is bool) &&
             (!('miners' in data) || data.miners is map);
    }

    // Helper to check if balance increment is valid based on a task
    function isValidTaskReward(userId) {
      let oldTasks = resource.data.get('completedTasks', []);
      let newTasks = request.resource.data.completedTasks;
      let addedTasks = newTasks.toSet().difference(oldTasks.toSet());
      
      // If exactly one task was added
      return addedTasks.size() == 1 &&
             // For now, we allow the increment if it's a positive number and the user is adding a task
             request.resource.data.balance > resource.data.balance;
    }

    function isValidWelcomeClaim() {
      return !resource.data.get('welcomeBonusClaimed', false) && 
             request.resource.data.welcomeBonusClaimed == true &&
             (request.resource.data.balance == resource.data.balance + 3000 || 
              request.resource.data.balance == resource.data.balance + 5000);
    }

    function isValidGame(data) {
      return data.players is list && data.players.size() < 50 &&
             data.totalPot is number && data.totalPot >= 0 &&
             data.status in ['waiting', 'drawing', 'winner'];
    }

    function isValidTransaction(data) {
      return data.keys().hasAll(['id', 'uid', 'amount', 'type', 'status', 'createdAt']) &&
             data.id is string &&
             data.uid == request.auth.uid &&
             data.amount is number && data.amount > 0 &&
             data.type in ['deposit', 'withdrawal'] &&
             data.status in ['pending', 'completed', 'failed'] &&
             data.createdAt is timestamp;
    }

    function isValidWinner(data) {
      return data.keys().hasAll(['id', 'gameId', 'uid', 'username', 'amount', 'createdAt']) &&
             data.id is string &&
             data.gameId is string &&
             data.uid is string &&
             data.username is string &&
             data.amount is number && data.amount >= 0 &&
             data.createdAt is timestamp;
    }

    function isValidStats(data) {
      return data.keys().hasAll(['lastWinner', 'topWinner']) &&
             data.lastWinner is map &&
             data.topWinner is map;
    }

    function isValidTask(data) {
      return data.keys().hasAll(['id', 'title', 'reward', 'type']) &&
             data.id is string &&
             data.title is string && data.title.size() < 100 &&
             data.reward is number &&
             data.type in ['daily', 'partner', 'achievement', 'social'];
    }

    function isValidPromoCode(data) {
      return data.keys().hasAll(['code', 'reward', 'supply']) &&
             data.code is string && data.code.size() < 50 &&
             data.reward is number &&
             data.supply is int;
    }

    function isValidReferralLink(data) {
      return data.keys().hasAll(['id', 'name']) &&
             data.id is string &&
             data.name is string && data.name.size() < 100;
    }

    function isValidWithdrawalOffer(data) {
      return data.keys().hasAll(['id', 'title', 'minAmount', 'maxAmount']) &&
             data.id is string &&
             data.title is string &&
             data.minAmount is number &&
             data.maxAmount is number;
    }

    function isValidAnalytics(data) {
      return true; // Analytics are usually updated by server or admin
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /stats/{statId} {
      allow read: if true;
      allow write: if isAuthenticated() && isValidStats(request.resource.data);
    }

    match /tasks/{taskId} {
      allow read: if true;
      allow write: if isAdmin() && isValidTask(request.resource.data);
    }

    match /promoCodes/{codeId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() && isValidPromoCode(request.resource.data);
    }

    match /referralLinks/{linkId} {
      allow read: if true;
      allow write: if isAdmin() && isValidReferralLink(request.resource.data);
    }

    match /withdrawalOffers/{offerId} {
      allow read: if true;
      allow write: if isAdmin() && isValidWithdrawalOffer(request.resource.data);
    }

    match /analytics/{analyticsId} {
      allow read: if isAdmin();
      allow write: if isAdmin() && isValidAnalytics(request.resource.data);
    }

    match /users/{userId} {
      allow get: if isAuthenticated();
      allow list: if isAdmin() || (request.query.limit != null && request.query.limit <= 100);
      allow create: if isOwner(userId) && isValidUser(request.resource.data) && 
                     (request.resource.data.role == 'user' || isAllowedAdmin(request.resource.data)) &&
                     request.resource.data.balance == 10 && 
                     request.resource.data.tonBalance == 1000;
      allow update: if isAdmin() || (
        isOwner(userId) && isValidUser(request.resource.data) &&
        request.resource.data.uid == resource.data.uid &&
        request.resource.data.role == resource.data.role &&
        (
          // Case 1: Just updating profile (no balance change)
          (request.resource.data.balance == resource.data.balance && 
           request.resource.data.tonBalance == resource.data.tonBalance) ||
          
          // Case 2: Claiming Welcome Bonus
          isValidWelcomeClaim() ||
          
          // Case 3: Completing a Task
          (isValidTaskReward(userId) && request.resource.data.tonBalance == resource.data.tonBalance) ||

          // Case 4: Spending TON in shop (decrement only)
          (request.resource.data.tonBalance < resource.data.tonBalance && 
           request.resource.data.balance == resource.data.balance) ||

          // Case 5: Arena Bid (DUCK spending)
          (request.resource.data.balance < resource.data.balance && 
           request.resource.data.volume >= resource.data.get('volume', 0) &&
           (!('spinsCount' in request.resource.data) || request.resource.data.spinsCount >= resource.data.get('spinsCount', 0)))
        )
      );
    }

    match /games/{gameId} {
      allow read: if true; // Publicly readable for live game
      allow create, update: if isAuthenticated() && isValidGame(request.resource.data);
    }

    match /transactions/{transactionId} {
      allow read: if isOwner(resource.data.uid) || isAdmin();
      allow create: if isAuthenticated() && isValidTransaction(request.resource.data);
      allow update: if isAdmin();
    }

    match /winners/{winnerId} {
      allow read: if true; // Publicly readable for leaderboard
      allow create: if isAuthenticated() && isValidWinner(request.resource.data);
      allow update: if isAdmin();
    }

    // Default deny
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
