{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Stores user balance, wins, and other profile data.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Unique user ID from Firebase Auth." },
        "username": { "type": "string", "description": "User's display name or Telegram handle." },
        "avatar": { "type": "string", "description": "URL to the user's profile image." },
        "balance": { "type": "number", "description": "User's current DUCK balance." },
        "tonBalance": { "type": "number", "description": "User's current TON balance." },
        "wins": { "type": "integer", "description": "Total number of games won." },
        "volume": { "type": "number", "description": "Total DUCK volume wagered." },
        "completedTasks": { "type": "array", "items": { "type": "string" }, "description": "List of IDs for completed tasks." },
        "referralCode": { "type": "string", "description": "Unique referral code for the user." },
        "referredBy": { "type": "string", "description": "UID of the user who referred this user." },
        "referralsCount": { "type": "integer", "description": "Number of users referred." },
        "totalDeposited": { "type": "number", "description": "Total DUCK deposited." },
        "totalWithdrawn": { "type": "number", "description": "Total DUCK withdrawn." },
        "adsViewed": { "type": "integer", "description": "Total ads viewed." },
        "spinsCount": { "type": "integer", "description": "Total spins performed." },
        "promosUsed": { "type": "integer", "description": "Total promo codes used." },
        "shopPurchases": { "type": "array", "items": { "type": "string" }, "description": "List of shop items purchased." },
        "selectedFrame": { "type": "string", "description": "ID of the currently selected profile frame." },
        "unlockedFrames": { "type": "array", "items": { "type": "string" }, "description": "List of frame IDs unlocked by the user." },
        "walletAddress": { "type": "string", "description": "Connected TON wallet address." },
        "role": { "type": "string", "enum": ["user", "admin"], "description": "User's role for access control." },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "username", "balance", "role"]
    },
    "Transaction": {
      "title": "Financial Transaction",
      "description": "Stores DUCK deposit and withdrawal records.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "uid": { "type": "string" },
        "amount": { "type": "number" },
        "type": { "type": "string", "enum": ["deposit", "withdrawal"] },
        "status": { "type": "string", "enum": ["pending", "completed", "failed"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "uid", "amount", "type", "status", "createdAt"]
    },
    "Winner": {
      "title": "Game Winner",
      "description": "Stores records of game winners for the leaderboard.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "gameId": { "type": "string" },
        "uid": { "type": "string" },
        "username": { "type": "string" },
        "avatar": { "type": "string" },
        "amount": { "type": "number" },
        "winChance": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "gameId", "uid", "username", "amount", "createdAt"]
    },
    "Game": {
      "title": "Game Session",
      "description": "Stores current or past game session data.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "players": { "type": "array", "description": "List of player objects in the current game." },
        "totalPot": { "type": "number" },
        "winner": { "type": "object", "description": "The winning player object." },
        "status": { "type": "string", "enum": ["waiting", "drawing", "winner"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "players", "totalPot", "status"]
    },
    "WinnerStats": {
      "title": "Global Winner Stats",
      "description": "Stores the top and last winner data.",
      "type": "object",
      "properties": {
        "lastWinner": { "type": "object", "description": "The most recent winner." },
        "topWinner": { "type": "object", "description": "The winner with the largest pot." }
      }
    },
    "Task": {
      "title": "Game Task",
      "description": "A task for users to complete for rewards.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "reward": { "type": "number" },
        "rewardType": { "type": "string", "enum": ["TON", "DUCK"] },
        "type": { "type": "string", "enum": ["daily", "partner", "achievement"] },
        "verificationType": { "type": "string", "enum": ["none", "channel", "group", "bot", "referral", "game", "win", "deposit", "purchase"] },
        "btn": { "type": "string" },
        "link": { "type": "string" },
        "requiredCount": { "type": "number", "description": "Threshold for achievement tasks (e.g., 5 referrals)." },
        "color": { "type": "string", "description": "Custom hex color for the task." },
        "icon": { "type": "string", "description": "Lucide icon name." },
        "completedCount": { "type": "integer" },
        "createdAt": { "type": "string", "format": "date-time" },
        "deleted": { "type": "boolean" }
      },
      "required": ["id", "title", "reward", "rewardType", "type", "verificationType"]
    },
    "PromoCode": {
      "title": "Promo Code",
      "description": "A code users can redeem for DUCK or TON.",
      "type": "object",
      "properties": {
        "code": { "type": "string" },
        "reward": { "type": "number" },
        "supply": { "type": "integer" },
        "claimedBy": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["code", "reward", "supply"]
    },
    "ReferralLink": {
      "title": "Referral Link",
      "description": "A custom referral link for partners.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "joins": { "type": "integer" },
        "ads": { "type": "integer" },
        "revenue": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name"]
    },
    "WithdrawalOffer": {
      "title": "Withdrawal Offer",
      "description": "Dynamic withdrawal limits and offers.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "minAmount": { "type": "number" },
        "maxAmount": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "title", "minAmount", "maxAmount"]
    },
    "Analytics": {
      "title": "App Analytics",
      "description": "Global application usage statistics.",
      "type": "object",
      "properties": {
        "totalUsers": { "type": "integer" },
        "joinedToday": { "type": "integer" },
        "activeToday": { "type": "integer" },
        "rewardAds": { "type": "integer" },
        "interstitials": { "type": "integer" },
        "totalSpins": { "type": "integer" },
        "pendingWithdrawals": { "type": "integer" },
        "totalRevenue": { "type": "number" },
        "promosClaimed": { "type": "integer" },
        "tasksDone": { "type": "integer" },
        "totalBalance": { "type": "number" }
      }
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile documents."
    },
    "/games/{gameId}": {
      "schema": "Game",
      "description": "Game session documents."
    },
    "/transactions/{transactionId}": {
      "schema": "Transaction",
      "description": "DUCK deposit and withdrawal records."
    },
    "/winners/{winnerId}": {
      "schema": "Winner",
      "description": "Recent game winners."
    },
    "/stats/{statId}": {
      "schema": "WinnerStats",
      "description": "Global game statistics."
    },
    "/tasks/{taskId}": {
      "schema": "Task",
      "description": "Manageable tasks."
    },
    "/promoCodes/{codeId}": {
      "schema": "PromoCode",
      "description": "Redeemable promo codes."
    },
    "/referralLinks/{linkId}": {
      "schema": "ReferralLink",
      "description": "Partner referral links."
    },
    "/withdrawalOffers/{offerId}": {
      "schema": "WithdrawalOffer",
      "description": "Withdrawal offers and limits."
    },
    "/analytics/{analyticsId}": {
      "schema": "Analytics",
      "description": "App-wide analytics."
    }
  }
}
